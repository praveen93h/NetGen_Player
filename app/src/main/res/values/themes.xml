<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for activities before Compose takes over -->
    <style name="Theme.NextGenPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Player activity theme - fullscreen immersive -->
    <style name="Theme.NextGenPlayer.Player">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>
</resources>
